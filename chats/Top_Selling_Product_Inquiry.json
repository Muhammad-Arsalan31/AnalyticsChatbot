        "role": "assistant",
        "content": "### Business Summary\n**Product 3 ka Market**: Product 3 ka market share aur sales data dekhne se pata chalta hai ke yeh product **F.B.AREA BLOCK-3**, **GULSHAN-E-IQBAL BLOCK-5**, aur **F.B.AREA BLOCK-13** me sab se zyada popular hai, jahan **Internal Sales** respectively PKR 69,773,820.00, PKR 54,719,396.00, aur PKR ",
        "sql": "WITH Internal AS (\n  SELECT \n    ib.name AS brick_name, \n    SUM(ms.total_amount) AS internal_sales\n  FROM master_sale ms\n  JOIN customer_details cd ON ms.customer_id = cd.customer_id\n  JOIN ims_brick ib ON cd.ims_brick_id = ib.id\n  WHERE ms.product_name = 'Product 3'\n  GROUP BY ib.name\n),\nMarket AS (\n  SELECT \n    ib.name AS brick_name, \n    SUM(s.unit) AS market_sales\n  FROM ims_sale s\n  JOIN ims_brick ib ON s.\"brickId\" = ib.id\n  WHERE s.product_id IN (SELECT id FROM products WHERE name = 'Product 3')\n  GROUP BY ib.name\n)\nSELECT \n  COALESCE(i.brick_name, m.brick_name) AS \"Brick Name\", \n  COALESCE(i.internal_sales, 0) AS \"Internal Sales\", \n  COALESCE(m.market_sales, 0) AS \"Market Sales\",\n  ROUND(COALESCE(i.internal_sales, 0) / COALESCE(m.market_sales, 1), 4) * 100 AS \"Market Share %\"\nFROM Internal i\nFULL OUTER JOIN Market m ON i.brick_name = m.brick_name\nORDER BY \"Internal Sales\" DESC;",
